# Apify
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
APIFY_ACTOR_ID=apify/instagram-reel-scraper

# Airtable
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appkRJOlid6jE4t6A
CREATORS_TABLE=Creadores
REELS_TABLE=Reels

# Comportamiento
DEFAULT_RESULTS_LIMIT=30
FIRST_RUN_LOOKBACK=3 months

# Batched (todas las fuentes en 1-2 corridas por plataforma)
IG_BATCH_MAX_RESULTS=5
IG_RECENT_LOOKBACK=2 days
YT_BATCH_MAX_RESULTS=3
YT_BATCH_MAX_SHORTS=0
YT_RECENT_LOOKBACK=2 days

# Ejecución de actores (reintento si la cuenta Apify se queda sin cupo de memoria)
APIFY_RUN_MEMORY_MB=0
APIFY_MAX_RETRIES=4
APIFY_RETRY_BASE_MS=30000

# YouTube (búsqueda por palabra clave)
ENABLE_YOUTUBE=true
YT_ACTOR_ID=streamers/youtube-scraper
YT_DEFAULT_MAX_RESULTS=5
YT_FIRST_RUN_LOOKBACK=7 days
YT_DOWNLOAD_SUBTITLES=true

# Seguridad del webhook manual (genera un string aleatorio)
TRIGGER_SECRET=cambia-esto-por-un-secreto-largo

# Transcripción de reels vía OpenRouter (opcional; se activa solo si hay API key)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
ENABLE_TRANSCRIPTION=true
TRANSCRIBE_MODEL=openai/gpt-4o-mini-transcribe
TRANSCRIBE_FORMAT=m4a

# Supabase: destino primario del contenido scrapeado y fuente del dashboard de curación.
# CUENTA: el proyecto de Supabase está bajo el correo myframify@gmail.com
# (proyecto "DISECTA", ref xtzwxraqnfqbdvvvytib). Si necesitas entrar a la consola, es con ese correo.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...  # service_role (Settings > API), NO la anon key
# SUPABASE_IG_TABLE=ig_reels
# SUPABASE_YT_TABLE=yt_videos

# Cloudflare R2 (opcional): rehospeda thumbnails para que no expiren. Se activa con las 4 + base URL.
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=competencia-media
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev  # o tu dominio propio del bucket

# Telegram (opcional): disparo manual desde el bot. Se activa solo si hay token.
TELEGRAM_BOT_TOKEN=123456:ABC-tu-token-de-botfather
TELEGRAM_ALLOWED_CHAT_IDS=123456789
# TELEGRAM_WEBHOOK_SECRET (opcional; por defecto usa TRIGGER_SECRET)

# Cron interno (el mismo servicio se auto-dispara). Apágalo con ENABLE_CRON=false.
ENABLE_CRON=true
CRON_SCHEDULE=0 8 * * *
CRON_TZ=America/Mexico_City

# Puerto (Railway lo inyecta automáticamente)
PORT=3000
